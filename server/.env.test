NODE_ENV=test
LOG_LEVEL=error
PORT=not-used-in-tests
SESSION_SECRET=test-session-secret-do-not-use-in-production
CLIENT_ORIGIN=not-used-in-tests
# NEO4J_URL is overridden at runtime by testcontainers via setup.ts
NEO4J_URL=placeholder
NEO4J_USERNAME=placeholder
NEO4J_PASSWORD=placeholder
REDIS_URL=placeholder
REDIS_PORT=placeholder
EMBEDDER_URL=placeholder
# Dummy R2 values — replace with real ones if tests exercise R2 directly
R2_ACCOUNT_ID=not-used-in-tests
R2_ACCESS_KEY_ID=not-used-in-tests
R2_SECRET_ACCESS_KEY=not-used-in-tests
R2_BUCKET_NAME=not-used-in-tests